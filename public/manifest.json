{
  "manifest_version": 3,
  "name": "spandan - a background music extension",
  "version": "0.0.1",
  "description": "Automatically pause and resume background music tabs while you browse.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon_16.png",
    "32": "icon_32.png",
    "48": "icon_48.png",
    "128": "icon_128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Spandan",
    "default_icon": {
      "16": "icon_16.png",
      "32": "icon_32.png"
    }
  },
  "options_page": "options/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "type": "module"
    }
  ]
}
